---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<article
  class:list={[
    'prose prose-lg dark:prose-invert',
    'prose-headings:font-serif prose-headings:font-semibold prose-headings:tracking-tight',
    'prose-h2:mt-12 prose-h2:text-2xl prose-h3:text-xl',
    'prose-p:leading-relaxed',
    'prose-a:text-accent prose-a:underline-offset-2 hover:prose-a:underline dark:prose-a:text-accent-dark',
    'prose-blockquote:border-l-2 prose-blockquote:border-accent prose-blockquote:not-italic prose-blockquote:text-ink-muted dark:prose-blockquote:border-accent-dark dark:prose-blockquote:text-ink-muted-dark',
    'prose-img:border prose-img:border-rule dark:prose-img:border-rule-dark',
    'prose-hr:my-12',
    className,
  ]}
>
  <slot />
</article>
