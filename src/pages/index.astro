---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import ScenarioCard from '~/components/ScenarioCard.astro';

const all = await getCollection('scenarios', (entry) => {
  // Show drafts in dev so we can preview them; hide in production builds.
  return import.meta.env.DEV ? true : entry.data.status === 'published';
});

const scenarios = all.sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);
---

<BaseLayout
  title="Possible Earths"
  description="A gallery of counterfactual-geography scenarios visualized through before/after maps and short essays."
>
  <section class="border-b border-rule dark:border-rule-dark">
    <div class="wrap py-16 sm:py-24">
      <p class="label mb-4">Counterfactual geography</p>
      <h1 class="font-serif text-4xl font-semibold leading-[1.05] tracking-tight text-ink dark:text-ink-dark sm:text-6xl">
        What if the Earth were
        <span class="text-accent dark:text-accent-dark">a little different?</span>
      </h1>
      <p class="mt-6 max-w-prose font-serif text-lg leading-relaxed text-ink-muted dark:text-ink-muted-dark">
        Move the Sahara north. Drain the Mediterranean. Flatten the Alps. We render the climate
        consequences as before-and-after maps and write short essays about what they tell us — and
        what they don't.
      </p>
    </div>
  </section>

  <section class="border-b border-rule dark:border-rule-dark">
    <div class="wrap grid gap-8 py-12 sm:grid-cols-2">
      <div>
        <h2 class="label mb-3 text-accent dark:text-accent-dark">What this is</h2>
        <p class="font-serif leading-relaxed">
          A small editorial gallery. Each scenario pairs a short essay with maps in four views —
          terrain, satellite, Köppen climate, and surface temperature — generated by{' '}
          <a
            href="https://orogen.studio"
            rel="noopener"
            class="text-accent underline-offset-2 hover:underline dark:text-accent-dark"
          >
            Orogen
          </a>, a browser-based procedural climate model.
        </p>
      </div>
      <div>
        <h2 class="label mb-3 text-ink-muted dark:text-ink-muted-dark">What it isn't</h2>
        <p class="font-serif leading-relaxed text-ink-muted dark:text-ink-muted-dark">
          A research tool. The climate maps are <em>scientifically informed, not necessarily
          physically accurate</em>. For real climate projections see Copernicus CDS and CMIP6.
        </p>
      </div>
    </div>
  </section>

  <section class="wrap py-12 sm:py-16">
    <h2 class="label mb-6">Scenarios</h2>
    {
      scenarios.length === 0 ? (
        <p class="font-serif text-ink-muted dark:text-ink-muted-dark">No scenarios published yet.</p>
      ) : (
        <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {scenarios.map((entry) => (
            <li>
              <ScenarioCard entry={entry} />
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>
